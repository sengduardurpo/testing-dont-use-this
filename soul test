-- Fitur Tween ke chest loop + auto press E
local autoTweenEnabled = false

local function getNearestChest()
    local hrp = getHRP()
    if not hrp then return nil end
    
    local nearest, minDist = nil, math.huge
    for _, chest in pairs(workspace.Treasures:GetChildren()) do
        local root = chest:FindFirstChildWhichIsA("BasePart") or chest.PrimaryPart
        if root then
            local dist = (hrp.Position - root.Position).Magnitude
            if dist < minDist then
                minDist = dist
                nearest = chest
            end
        end
    end
    return nearest
end

local function autoPressE(chest)
    local hrp = getHRP()
    local root = chest:FindFirstChildWhichIsA("BasePart") or chest.PrimaryPart
    if not hrp or not root then return end
    
    if (hrp.Position - root.Position).Magnitude < 5 then  -- dekat chest
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        task.wait(0.1)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        print("Auto press E di chest")
    end
end

local function startAutoTweenChest()
    autoTweenEnabled = true
    spawn(function()
        while autoTweenEnabled do
            local chest = getNearestChest()
            if chest then
                local root = chest:FindFirstChildWhichIsA("BasePart") or chest.PrimaryPart
                if root then
                    tweenToPosition(root.Position + Vector3.new(0, 3, 0))  -- di atas chest
                    task.wait(0.5)
                    autoPressE(chest)  -- auto E saat dekat
                end
            end
            task.wait(1)  -- delay antar tween
        end
    end)
end

