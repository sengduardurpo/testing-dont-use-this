espFolder.Parent = ScreenGui

local function createChestESP(chest)
    local root = chest:FindFirstChildWhichIsA("BasePart") or chest.PrimaryPart
    if not root then return end
    
    local hl = Instance.new("Highlight")
    hl.FillColor = Color3.fromRGB(255, 215, 0)
    hl.OutlineColor = Color3.fromRGB(255, 165, 0)
    hl.FillTransparency = 0.6
    hl.OutlineTransparency = 0.2
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Adornee = chest
    hl.Parent = espFolder
    
    local bb = Instance.new("BillboardGui")
    bb.Adornee = root
    bb.Size = UDim2.new(0, 200, 0, 50)
    bb.StudsOffset = Vector3.new(0, 3, 0)
    bb.AlwaysOnTop = true
    bb.MaxDistance = math.huge  -- Super jauh (infinite distance)
    bb.Parent = espFolder
    
    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1, 0, 1, 0)
    text.BackgroundTransparency = 1
    text.TextColor3 = Color3.fromRGB(255, 255, 100)
    text.TextStrokeTransparency = 0.5
    text.TextStrokeColor3 = Color3.new(0,0,0)
    text.Font = Enum.Font.SourceSansBold
    text.TextSize = 18
    text.Text = "Chest"
    text.Parent = bb
    
    chest:SetAttribute("ESPHighlight", hl)
    chest:SetAttribute("ESPBillboard", bb)
    chest:SetAttribute("ESPLabel", text)
end

local function removeChestESP(chest)
    local hl = chest:GetAttribute("ESPHighlight")
    if hl then hl:Destroy() end
    local bb = chest:GetAttribute("ESPBillboard")
    if bb then bb:Destroy() end
    chest:SetAttribute("ESPHighlight", nil)
    chest:SetAttribute("ESPBillboard", nil)
    chest:SetAttribute("ESPLabel", nil)
end

local function updateChestDistance()
    if not espEnabled then return end
    local hrp = getHRP()
    if not hrp then return end
    for _, chest in pairs(workspace.Treasures:GetChildren()) do
        local root = chest:FindFirstChildWhichIsA("BasePart") or chest.PrimaryPart
        if not root then continue end
        local label = chest:GetAttribute("ESPLabel")
        if label then
            local dist = (hrp.Position - root.Position).Magnitude
            label.Text = string.format("Chest (%.1f studs)", dist)
        end
    end
end

local function toggleESP(state)
    espEnabled = state
    if not state then
        espFolder:ClearAllChildren()
        for _, chest in pairs(workspace.Treasures:GetChildren()) do
            removeChestESP(chest)
        end
        return
    end
    for _, chest in pairs(workspace.Treasures:GetChildren()) do
        createChestESP(chest)
    end
end

workspace.Treasures.ChildAdded:Connect(function(child)
    if espEnabled then
        createChestESP(child)
    end
end)

workspace.Treasures.ChildRemoved:Connect(function(child)
    removeChestESP(child)
end)

